# ---------------------------------------------------------
# Cognitive Memory System - Environment Configuration
# ---------------------------------------------------------

# ตั้งค่า true เพื่อใช้ตัวจำลอง (Mock), false เพื่อยิง API จริง
USE_MOCK_AI=false

# API Keys (ใส่ค่าจริงในไฟล์ .env เท่านั้น ห้ามใส่ใน .env.example)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# API Base URL สำหรับโมเดล (เช่น Router Service)
OPENAI_BASE_URL=https://router.nextbrain.me/v1

# Neo4j Database Configuration
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

REDIS_HOST=127.0.0.1
REDIS_PORT=6379